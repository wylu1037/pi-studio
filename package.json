{
  "name": "pi-studio",
  "version": "0.1.0",
  "description": "A local-first desktop control panel for Pi agents.",
  "author": "Pi Studio contributors",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "app:dev": "electron .",
    "app:prepare": "node scripts/prepare-electron.mjs",
    "app:rebuild": "node scripts/rebuild-electron-native.mjs",
    "app:bundle": "pnpm build && pnpm app:prepare && pnpm app:rebuild",
    "app:build:dir": "pnpm app:bundle && electron-builder --projectDir electron --config ../electron-builder.yml --dir",
    "app:build": "pnpm app:bundle && electron-builder --projectDir electron --config ../electron-builder.yml",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx lib/db/seed.ts",
    "api:schema": "tsx scripts/write-openapi.ts",
    "api:gen": "pnpm run api:schema && kubb generate",
    "pi:version": "pi --version"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@hono/zod-openapi": "^1.4.0",
    "@hookform/resolvers": "^5.4.0",
    "@monaco-editor/react": "^4.7.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.101.2",
    "@vercel/analytics": "1.6.1",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "4.12.25",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.16.0",
    "monaco-editor": "^0.55.1",
    "next": "16.2.6",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "typebox": "^1.3.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@kubb/plugin-axios": "5.0.0-beta.87",
    "@kubb/plugin-client": "4.39.2",
    "@kubb/plugin-oas": "^4.39.2",
    "@kubb/plugin-react-query": "^4.39.2",
    "@kubb/plugin-ts": "^4.39.2",
    "@kubb/plugin-zod": "^4.39.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "electron": "39.8.10",
    "electron-builder": "^26.0.12",
    "eslint": "^10.6.0",
    "kubb": "^3.2.2",
    "node-gyp": "^12.4.0",
    "postcss": "^8.5",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.23.0",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.63.0"
  }
}
